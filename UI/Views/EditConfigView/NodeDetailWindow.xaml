<Window x:Class="ExShrinkSidebar.UI.Views.EditConfigView.NodeDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="更多参数"
        Height="360"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF2D2D30">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText"
                   Grid.Row="0"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <Grid x:Name="PathRow" Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="PathLabel" Grid.Column="0" VerticalAlignment="Center" Foreground="White" Text=""/>
            <TextBox x:Name="PathBox" Grid.Column="1" Margin="0,0,8,0" Background="#333" Foreground="White" BorderThickness="0" Padding="8,6"/>
            <Button x:Name="BrowseBtn" Grid.Column="2" Content="" Click="BrowseBtn_Click"/>
        </Grid>

        <Grid x:Name="ArgumentsRow" Grid.Row="2" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="ArgumentsLabel" Grid.Column="0" VerticalAlignment="Center" Foreground="White" Text="参数"/>
            <TextBox x:Name="ArgumentsBox" Grid.Column="1" Background="#333" Foreground="White" BorderThickness="0" Padding="8,6"/>
        </Grid>

        <CheckBox x:Name="EnablePlacementCheckBox"
                  Grid.Row="3"
                  Margin="0,0,0,10"
                  Foreground="White"
                  Content=""
                  Visibility="Collapsed"
                  Checked="EnablePlacementCheckBox_Changed"
                  Unchecked="EnablePlacementCheckBox_Changed"/>

        <Grid x:Name="PlacementRow" Grid.Row="4" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="CornerLabel" Grid.Column="0" VerticalAlignment="Center" Foreground="White" Text="角落"/>
            <ComboBox x:Name="CornerBox" Grid.Column="1" Margin="0,0,8,0"/>
            <TextBlock x:Name="WidthLabel" Grid.Column="2" VerticalAlignment="Center" Foreground="White" Text="宽"/>
            <TextBox x:Name="WidthBox" Grid.Column="3" Margin="0,0,8,0" Background="#333" Foreground="White" BorderThickness="0" Padding="8,6"/>
            <TextBlock x:Name="HeightLabel" Grid.Column="4" VerticalAlignment="Center" Foreground="White" Text="高"/>
            <TextBox x:Name="HeightBox" Grid.Column="5" Background="#333" Foreground="White" BorderThickness="0" Padding="8,6"/>
        </Grid>

        <Border Grid.Row="5" Background="#223D3D40" CornerRadius="6" Padding="12">
            <TextBlock x:Name="HintText"
                       Foreground="#FFD0D0D0"
                       TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CancelBtn" Width="90" Margin="0,0,8,0" Content="取消" Click="CancelBtn_Click"/>
            <Button x:Name="ConfirmBtn" Width="90" Content="确定" Click="ConfirmBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
