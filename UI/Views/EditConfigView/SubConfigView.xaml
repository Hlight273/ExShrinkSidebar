<UserControl x:Class="ExShrinkSidebar.UI.Views.EditConfigView.SubConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 节点行 -->
        <Border x:Name="NodeBorder" Background="Transparent" BorderBrush="#444" BorderThickness="0,0,0,1" Padding="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- 缩进 -->
                    <ColumnDefinition Width="24"/>
                    <!-- 展开/收起 -->
                    <ColumnDefinition Width="70"/>
                    <!-- 类型 -->
                    <ColumnDefinition Width="*"/>
                    <!-- 名称 -->
                    <ColumnDefinition Width="*"/>
                    <!-- 参数编辑 -->
                    <ColumnDefinition Width="24"/>
                    <!-- 添加 -->
                    <ColumnDefinition Width="24"/>
                    <!-- 删除 -->
                </Grid.ColumnDefinitions>

                <!-- 缩进 -->
                <Border x:Name="IndentPad" Grid.Column="0"/>

                <!-- 展开/收起 -->
                <ToggleButton x:Name="ExpandBtn" Grid.Column="1" Content="+" FontSize="10" 
                              Visibility="Collapsed" Click="ExpandBtn_Click"/>

                <!-- 类型 -->
                <ComboBox x:Name="TypeComboBox" Grid.Column="2" FontSize="12" 
                          SelectionChanged="TypeComboBox_SelectionChanged"/>

                <!-- 名称 -->
                <TextBox x:Name="NameTextBox" Grid.Column="3" Margin="2,0" VerticalAlignment="Center" 
                         Background="#333" Foreground="White" BorderThickness="0" 
                         TextChanged="NameTextBox_TextChanged"/>

                <!-- 参数编辑区 -->
                <Grid Grid.Column="4" x:Name="EditArea" Margin="5,0">
                    <!-- 脚本 -->
                    <TextBox x:Name="ScriptBox" Visibility="Collapsed" VerticalAlignment="Center" 
                             Background="#333" Foreground="White" BorderThickness="0"
                             TextChanged="ScriptBox_TextChanged"/>
                    <!-- 路径 -->
                    <DockPanel x:Name="PathPanel" Visibility="Collapsed">
                        <Button Content="..." Width="20" DockPanel.Dock="Right" Click="BrowsePath_Click"/>
                        <TextBox x:Name="PathBox" VerticalAlignment="Center" 
                                 Background="#333" Foreground="White" BorderThickness="0"
                                 TextChanged="PathBox_TextChanged"/>
                    </DockPanel>
                </Grid>

                <!-- 添加子节点 (仅 Combine 类型有效，可在 CodeBehind 控制 Visibility) -->
                <Button Grid.Column="5" Content="+" Width="20" FontSize="12" Click="AddChildBtn_Click"/>

                <!-- 删除 -->
                <Button Grid.Column="6" Content="X" Width="20" FontSize="10" Click="DeleteBtn_Click"/>
            </Grid>
        </Border>

        <!-- 子节点容器 -->
        <StackPanel x:Name="ChildrenContainer" Grid.Row="1" Visibility="Collapsed"/>
    </Grid>
</UserControl>
