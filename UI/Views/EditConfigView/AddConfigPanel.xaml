<Window x:Class="ExShrinkSidebar.UI.Views.EditConfigView.AddConfigPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Config Editor"
        Height="560"
        Width="780"
        MinWidth="620"
        MinHeight="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#FF688BC3"/>
        <SolidColorBrush x:Key="PrimaryBlueHoverBrush" Color="#FF7A9AD0"/>
        <SolidColorBrush x:Key="PrimaryBlueSoftBrush" Color="#224A7CC2"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#334D5966"/>
        <SolidColorBrush x:Key="PanelGrayBrush" Color="#183B434D"/>

        <Style x:Key="CleanButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBlueHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResizeThumbBaseStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="Transparent" BorderThickness="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="{StaticResource PrimaryBlueBrush}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="Transparent" BorderThickness="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="#FF2D2D30" BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnDragMove">
                <TextBlock x:Name="TitleText"
                           Text="&#x811A;&#x672C;&#x914D;&#x7F6E;&#x7F16;&#x8F91;&#x5668;"
                           Foreground="White"
                           Margin="15,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"/>
                <Button x:Name="CloseBtn"
                        Content="&#x2715;"
                        Width="30"
                        Height="30"
                        Click="OnCloseClick"
                        Style="{StaticResource CleanButtonStyle}"
                        Foreground="#FFAAAAAA"
                        FontSize="14"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,10,0"/>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          CanContentScroll="False"
                          Padding="2">
                <StackPanel x:Name="TreeContainer" Margin="10,5,10,10"/>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,15">
                <Button x:Name="AddRootBtn"
                        Content="&#x6DFB;&#x52A0;&#x6839;&#x8282;&#x70B9;"
                        Click="OnAddRootClick"
                        Style="{StaticResource FlatButtonStyle}"
                        Margin="0,0,10,0"/>

                <Button x:Name="ConfirmBtn"
                        Content="&#x4FDD;&#x5B58;&#x5E76;&#x5173;&#x95ED;"
                        Click="OnConfirmClick"
                        Style="{StaticResource FlatButtonStyle}"/>
            </StackPanel>

            <primitives:Thumb Grid.RowSpan="3"
                              Panel.ZIndex="10"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              Margin="2"
                              Cursor="SizeNWSE"
                              Style="{StaticResource ResizeThumbBaseStyle}"
                              DragDelta="ResizeTopLeft_DragDelta">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid Background="Transparent">
                            <Path Data="M18,2 L2,2 L2,18"
                                  Stroke="#FF8E98A5"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Grid>
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>

            <primitives:Thumb Grid.RowSpan="3"
                              Panel.ZIndex="10"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Margin="2"
                              Cursor="SizeNESW"
                              Style="{StaticResource ResizeThumbBaseStyle}"
                              DragDelta="ResizeTopRight_DragDelta">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid Background="Transparent">
                            <Path Data="M2,2 L18,2 L18,18"
                                  Stroke="#FF8E98A5"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Grid>
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>

            <primitives:Thumb Grid.RowSpan="3"
                              Panel.ZIndex="10"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Bottom"
                              Margin="2"
                              Cursor="SizeNESW"
                              Style="{StaticResource ResizeThumbBaseStyle}"
                              DragDelta="ResizeBottomLeft_DragDelta">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid Background="Transparent">
                            <Path Data="M2,2 L2,18 L18,18"
                                  Stroke="#FF8E98A5"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Grid>
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>

            <primitives:Thumb Grid.RowSpan="3"
                              Panel.ZIndex="10"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="2"
                              Cursor="SizeNWSE"
                              Style="{StaticResource ResizeThumbBaseStyle}"
                              DragDelta="ResizeBottomRight_DragDelta">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid Background="Transparent">
                            <Path Data="M18,2 L18,18 L2,18"
                                  Stroke="#FF8E98A5"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Grid>
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>
        </Grid>
    </Border>
</Window>
