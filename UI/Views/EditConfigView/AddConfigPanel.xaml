<Window x:Class="ExShrinkSidebar.UI.Views.EditConfigView.AddConfigPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExShrinkSidebar.UI.Views.MainWindow"
        mc:Ignorable="d"
        Title="配置编辑器" Height="500" Width="450"
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="CleanButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 简单的按钮样式用于底部操作 -->
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF688BC3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- 窗口容器 -->
    <Border CornerRadius="10" Background="#FF2D2D30" BorderBrush="#FF688BC3" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnDragMove">
                <TextBlock x:Name="TitleText" Text="添加根配置" Foreground="White" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                <Button x:Name="CloseBtn" Content="✕" 
                        Width="30" Height="30" 
                        Click="OnCloseClick"
                        Style="{StaticResource CleanButtonStyle}"
                        Foreground="#FFAAAAAA" FontSize="14" 
                        HorizontalContentAlignment="Center" 
                        VerticalContentAlignment="Center"
                        HorizontalAlignment="Right" Margin="0,0,10,0"/>
            </Grid>

            <!-- 内容区域：改为 ScrollViewer 以支持长列表 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="TreeContainer" Margin="10,5,10,10">
                    <!-- 这里将动态加载 SubConfigView -->
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,15">
                <Button x:Name="AddRootBtn" Content="添加根节点" 
                        Click="OnAddRootClick"
                        Style="{StaticResource FlatButtonStyle}"
                        Margin="0,0,10,0"/>

                <Button x:Name="ConfirmBtn" Content="保存并关闭" 
                        Click="OnConfirmClick"
                        Style="{StaticResource FlatButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
