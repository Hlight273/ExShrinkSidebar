<UserControl x:Class="ExShrinkSidebar.UI.Views.MainWindow.DockPositionToggle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExShrinkSidebar.UI.Views.MainWindow"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="100" Width="100" Height="100">

    <Grid Width="100" Height="100">
        <!-- 上箭头 -->
        <Button x:Name="TopBtn" 
                Width="30" Height="30" 
                Click="OnClickTop" 
                Opacity="0.995" 
                Background="{x:Null}"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,15,0,0">
            <Image Source="/Asset/Texture/Common/arrow.png" 
                   Cursor="Hand" 
                   Stretch="None" 
                   RenderTransformOrigin="0.5,0.5"/>
        </Button>

        <!-- 下箭头 (旋转180度) -->
        <Button x:Name="BottomBtn" 
                Width="30" Height="30" 
                Click="OnClickBottom" 
                Opacity="0.995" 
                Background="{x:Null}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,15">
            <Image Source="/Asset/Texture/Common/arrow.png" 
                   Cursor="Hand" 
                   Stretch="None" 
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <RotateTransform Angle="180"/>
                </Image.RenderTransform>
            </Image>
        </Button>

        <!-- 左箭头 (旋转-90度) -->
        <Button x:Name="LeftBtn" 
                Width="30" Height="30" 
                Click="OnClickLeft" 
                Opacity="0.995" 
                Background="{x:Null}"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="15,0,0,0">
            <Image Source="/Asset/Texture/Common/arrow.png" 
                   Cursor="Hand" 
                   Stretch="None" 
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <RotateTransform Angle="-90"/>
                </Image.RenderTransform>
            </Image>
        </Button>

        <!-- 右箭头 (旋转90度) -->
        <Button x:Name="RightBtn" 
                Width="30" Height="30" 
                Click="OnClickRight" 
                Opacity="0.995" 
                Background="{x:Null}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,15,0">
            <Image Source="/Asset/Texture/Common/arrow.png" 
                   Cursor="Hand" 
                   Stretch="None" 
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <RotateTransform Angle="90"/>
                </Image.RenderTransform>
            </Image>
        </Button>

        <!-- 中心装饰圆点（可选） -->
        <Ellipse Width="20" Height="20" 
                 Fill="#FF63748A" 
                 Stroke="#555" 
                 StrokeThickness="1.5" 
                 Opacity="0.8"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Ellipse.ToolTip>中心点</Ellipse.ToolTip>
        </Ellipse>
    </Grid>
</UserControl>