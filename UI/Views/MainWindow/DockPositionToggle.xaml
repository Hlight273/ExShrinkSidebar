<UserControl x:Class="ExShrinkSidebar.UI.Views.MainWindow.DockPositionToggle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExShrinkSidebar.UI.Views.MainWindow"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="100" Width="100" Height="100">

    <UserControl.Resources>
        <!-- 定义公用的按钮样式：去除默认背景，添加图片高亮效果 -->
        <Style x:Key="ImageButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- 只展示内容，不添加任何默认装饰 -->
                        <ContentPresenter x:Name="contentPresenter" 
                                          ContentTemplate="{TemplateBinding ContentTemplate}" 
                                          Content="{TemplateBinding Content}" 
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Width="100" Height="100">
        <!-- 上箭头 -->
        <Button x:Name="TopBtn" 
                Width="30" Height="30" 
                Click="OnClickTop" 
                Style="{StaticResource ImageButtonStyle}"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,10,0,0">
            <Image Source="/Asset/Texture/Common/arrow.png" 
                   Cursor="Hand" 
                   Stretch="None" 
                   RenderTransformOrigin="0.5,0.5">
                <Image.Style>
                    <Style TargetType="Image">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- 鼠标悬停时增加亮度，这里使用白色遮罩模拟发光效果 -->
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" Color="White" Opacity="0.8" BlurRadius="5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
        </Button>

        <!-- 下箭头 (旋转180度) -->
        <Button x:Name="BottomBtn" 
                Width="30" Height="30" 
                Click="OnClickBottom" 
                Style="{StaticResource ImageButtonStyle}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,10">
            <Image Source="/Asset/Texture/Common/arrow.png" 
                   Cursor="Hand" 
                   Stretch="None" 
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <RotateTransform Angle="180"/>
                </Image.RenderTransform>
                <Image.Style>
                    <Style TargetType="Image">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" Color="White" Opacity="0.8" BlurRadius="5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
        </Button>

        <!-- 左箭头 (旋转-90度) -->
        <Button x:Name="LeftBtn" 
                Width="30" Height="30" 
                Click="OnClickLeft" 
                Style="{StaticResource ImageButtonStyle}"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="10,0,0,0">
            <Image Source="/Asset/Texture/Common/arrow.png" 
                   Cursor="Hand" 
                   Stretch="None" 
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <RotateTransform Angle="-90"/>
                </Image.RenderTransform>
                <Image.Style>
                    <Style TargetType="Image">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" Color="White" Opacity="0.8" BlurRadius="5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
        </Button>

        <!-- 右箭头 (旋转90度) -->
        <Button x:Name="RightBtn" 
                Width="30" Height="30" 
                Click="OnClickRight" 
                Style="{StaticResource ImageButtonStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,10,0">
            <Image Source="/Asset/Texture/Common/arrow.png" 
                   Cursor="Hand" 
                   Stretch="None" 
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <RotateTransform Angle="90"/>
                </Image.RenderTransform>
                <Image.Style>
                    <Style TargetType="Image">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" Color="White" Opacity="0.8" BlurRadius="5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
        </Button>

        <!-- 中心装饰圆点（可选） -->
        <Ellipse Width="20" Height="20" 
                 Fill="#FF688BC3" 
                 Stroke="#FF2D3065" 
                 StrokeThickness="1.5" 
                 Opacity="0.8"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Ellipse.ToolTip>中心点</Ellipse.ToolTip>
        </Ellipse>
    </Grid>
</UserControl>
