<local:WindowBase x:Class="ExShrinkSidebar.UI.Views.MainWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ExShrinkSidebar.UI.ViewModels.Common"
        xmlns:ctrl="clr-namespace:ExShrinkSidebar.UI.Views.MainWindow"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Height="150">
    
    

    <Grid>
        <!-- 主内容区 -->
        <Border Background="#DD1D1E22" CornerRadius="8" Padding="10">
            <StackPanel x:Name="InnerPanel"
                 Orientation="Horizontal"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
                <StackPanel x:Name="ButtonPanel"
                     Orientation="Horizontal"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
                <ctrl:AddConfigButton/>
            </StackPanel>
               
        </Border>

        <!-- 停靠位置控件 - 放在右上角 -->
        <ctrl:DockPositionToggle 
            Width="100" 
            Height="100"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,0,0,0"
            Opacity="0.8"/>

        <!-- 拖拽条 -->
        <Border x:Name="DragBar"
            Height="10"
            Background="#33FFFFFF"
            VerticalAlignment="Bottom"
            Cursor="SizeWE"
            MouseLeftButtonDown="DragBar_MouseDown"
            MouseMove="DragBar_MouseMove"
            MouseLeftButtonUp="DragBar_MouseUp"/>
    </Grid>
</local:WindowBase>
